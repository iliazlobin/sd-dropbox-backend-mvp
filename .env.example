# Dropbox MVP — environment variables
# Copy to .env and fill in values. The real .env is gitignored.

# PostgreSQL connection string (asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:port/database
DROPBOX_DATABASE_URL=postgresql+asyncpg://dropbox:dropbox@localhost:5432/dropbox

# Application listen port (inside container always 8000)
DROPBOX_APP_PORT=8000

# Local block storage directory (content-addressed by SHA-256)
DROPBOX_BLOCK_STORAGE_DIR=data/blocks
