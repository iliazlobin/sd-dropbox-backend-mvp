# Dropbox MVP — environment variables
# Copy this to .env and adjust for local development.

# PostgreSQL connection (async)
DATABASE_URL=postgresql+asyncpg://dropbox:dropbox@localhost:5432/dropbox

# Local filesystem block storage directory
BLOCK_STORAGE_DIR=data/blocks

# App listen port (inside container always 8000; host port via APP_PORT in compose)
APP_PORT=8010
