# Dropbox MVP — e2e acceptance contract
# Sourced by both CI (ci.yml e2e job) and host e2e-verify loop.
# Defines the four lifecycle commands plus test dependencies.

# ---- Lifecycle ----

UP='
set -e
docker compose up -d --build --wait
'

READY='
python -c "import urllib.request; urllib.request.urlopen(\"http://localhost:8000/healthz\")"
'

ACCEPTANCE='
pytest verify/acceptance/ -v
'

DOWN='
docker compose down --volumes
'

# ---- Test dependencies (pip packages needed for the acceptance suite) ----

TEST_DEPS='
pip install httpx pytest pytest-asyncio
'

# ---- App URL for acceptance tests ----
# Inside docker compose, the app listens on port 8000.
API_BASE_URL=http://localhost:8000
